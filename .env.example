# Copy this file to .env and fill in your keys. .env is gitignored.

# Groq baseline (scripts/baseline_groq.py)
GROQ_API_KEY=

# Reddit OFFICIAL API for collecting public r/anime posts
# (scripts/collect_reddit.py). Create a "script" app at
# https://www.reddit.com/prefs/apps to get the id + secret.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=takemeter:v1 (by /u/your_username)
